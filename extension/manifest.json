{
  "manifest_version": 3,
  "name": "Links Manager",
  "version": "1.0.0",
  "description": "Save links to your Links Manager boards with a right-click.",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["http://localhost:3001/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Links Manager"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
